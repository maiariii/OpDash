{
    "name": "ops-tracker-root",
    "version": "1.0.0",
    "description": "Root config for Vercel deployment",
    "scripts": {
        "start": "node api/index.js",
        "dev": "nodemon --ignore db.json --ignore db.backup.json --ignore api/debug_log.txt api/index.js",
        "dev:full": "concurrently \"npm run dev\" \"npm run dev --prefix client\"",
        "install-client": "cd client && npm install",
        "build-client": "cd client && npm run build"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "date-fns": "^4.1.0",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.18.0",
        "socket.io": "^4.8.3",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "nodemon": "^3.1.9"
    }
}